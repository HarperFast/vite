{
	"name": "@harperfast/vite",
	"version": "1.1.1",
	"description": "Plugin for running Vite applications inside Harper",
	"license": "Apache-2.0",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist/**",
		"!dist/**/*.test.*",
		"config.yaml",
		"schema.graphql",
		"schema.json",
		"LICENSE",
		"README.md"
	],
	"homepage": "https://github.com/HarperFast/vite",
	"bugs": {
		"url": "https://github.com/HarperFast/vite/issues",
		"email": "support@harperdb.io"
	},
	"author": {
		"name": "Harper",
		"email": "support@harperdb.io"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"harper:dev": "harper dev .",
		"test": "npm run build && node --test dist/index.test.js",
		"test:integration": "npm run build && node scripts/setup-fixture.mjs && HARPER_INTEGRATION_TEST_STARTUP_TIMEOUT_MS=120000 harper-integration-test-run --isolation=none dist/integration.test.js",
		"test:coverage": "npm run build && node --test --experimental-test-coverage dist/index.test.js",
		"format:check": "prettier . --check",
		"format:write": "prettier . --write",
		"prepublishOnly": "npm run build"
	},
	"peerDependencies": {
		"vite": ">= 7"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/HarperFast/vite"
	},
	"engines": {
		"node": ">=22"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=20",
			"onFail": "error"
		},
		"packageManager": {
			"name": "npm",
			"onFail": "error"
		}
	},
	"devDependencies": {
		"@commitlint/cli": "^20.0.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@harperdb/code-guidelines": "^0.0.6",
		"@harperfast/integration-testing": "^0.5.4",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.2",
		"@semantic-release/npm": "^13.1.1",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@types/node": "^24.12.0",
		"conventional-changelog-conventionalcommits": "^9.1.0",
		"harper": "^5.1.3",
		"prettier": "^3.8.1",
		"semantic-release": "^25.0.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.16"
	}
}
